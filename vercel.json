{
  "installCommand": "npm install",
  "buildCommand": "npm run build --workspace @sige/web",
  "outputDirectory": "apps/web/dist",
  "rewrites": [
    {
      "source": "/api/v1/:path*",
      "destination": "https://www.intellilaw.ai/api/v1/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
