{
  "name": "@sige/mobile",
  "version": "0.1.0",
  "private": true,
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "dev": "expo start --host lan --clear",
    "dev:client": "expo start --host tunnel --clear",
    "android": "expo start --android",
    "web": "expo start --web",
    "lint": "tsc -p tsconfig.json --noEmit",
    "build:android:development": "npx eas-cli build --platform android --profile development",
    "build:android:preview": "npx eas-cli build --platform android --profile preview",
    "build:android:production": "npx eas-cli build --platform android --profile production"
  },
  "dependencies": {
    "expo": "~54.0.34",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-webview": "^13.15.0"
  },
  "devDependencies": {
    "@expo/ngrok": "^4.1.3",
    "@types/react": "~19.1.10",
    "typescript": "~5.9.2"
  }
}
