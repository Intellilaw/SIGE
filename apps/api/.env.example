APP_ENV=development
API_PORT=4000
WEB_ORIGIN=https://app.example.com
WEB_ORIGINS=https://app.example.com,https://www.app.example.com
DATABASE_URL=postgresql://db_user:db_password@your-rds-endpoint:5432/sige_2?schema=public
JWT_ACCESS_SECRET=replace-with-a-64-char-secret-from-secrets-manager
JWT_REFRESH_SECRET=replace-with-a-second-64-char-secret-from-secrets-manager
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
AUTH_COOKIE_DOMAIN=.example.com
AUTH_COOKIE_SAME_SITE=lax
PASSWORD_RESET_TTL_MINUTES=120
PASSWORD_RESET_EXPOSE_PREVIEW=false
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_QUOTE_TRANSLATION_MODEL=gpt-4o-mini
OPENAI_QUOTE_TRANSLATION_TIMEOUT_MS=45000
