# API local development example.
# Copy to apps/api/.env.local and replace placeholders with your local PostgreSQL values.
# Local development refuses remote/RDS hosts.

APP_ENV=local
API_PORT=4000
WEB_ORIGIN=http://localhost:5173
WEB_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

DATABASE_URL=postgresql://<local_user>:<local_password>@localhost:5432/<local_database>?schema=public

SIGE_SKIP_LOCAL_POSTGRES=false
SIGE_LOCAL_POSTGRES_PORT=5432
SIGE_USE_RDS_TUNNEL=false

JWT_ACCESS_SECRET=replace-with-at-least-32-character-local-secret
JWT_REFRESH_SECRET=replace-with-another-32-character-local-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
AUTH_COOKIE_DOMAIN=
AUTH_COOKIE_SAME_SITE=lax

MANAGER_DE_ESCRITOS_URL=http://localhost:8000
SSO_SECRET_KEY=replace-with-the-shared-manager-sso-secret
SSO_ISSUER=sige
SSO_AUDIENCE=manager-de-escritos
PASSWORD_RESET_TTL_MINUTES=120
PASSWORD_RESET_EXPOSE_PREVIEW=true

OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_QUOTE_TRANSLATION_MODEL=gpt-4o-mini
OPENAI_QUOTE_TRANSLATION_TIMEOUT_MS=45000
OPENAI_LABOR_CONTRACT_MODEL=gpt-4o-mini
OPENAI_LABOR_CONTRACT_TIMEOUT_MS=60000
OPENAI_EXTERNAL_CONTRACT_MODEL=gpt-4o-mini
OPENAI_EXTERNAL_CONTRACT_TIMEOUT_MS=60000
OPENAI_RUSCONI_INTELLIGENCE_MODEL=gpt-5.5
OPENAI_RUSCONI_INTELLIGENCE_TIMEOUT_MS=60000

INTELLILAW_BOT_API_URL=http://localhost:8000
INTELLILAW_BOT_API_KEY=
INTELLILAW_BOT_PROMOTION_TIMEOUT_MS=180000
TELEGRAM_BOT_TOKEN=
TELEGRAM_GROUP_LOOKUP_TIMEOUT_MS=5000
