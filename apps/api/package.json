{
  "name": "@sige/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "lint": "tsc -p tsconfig.json --noEmit",
    "db:generate": "prisma generate",
    "db:seed": "tsx prisma/seed.ts",
    "users:extract": "tsx scripts/users/extract-intranet-users.ts",
    "users:import": "tsx scripts/users/import-intranet-users.ts"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "@fastify/helmet": "^13.0.0",
    "@fastify/jwt": "^9.1.0",
    "@fastify/rate-limit": "^10.3.0",
    "@prisma/client": "^6.5.0",
    "@sige/contracts": "0.1.0",
    "dotenv": "^16.4.7",
    "fastify": "^5.2.1",
    "pino-pretty": "^13.0.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "prisma": "^6.5.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
