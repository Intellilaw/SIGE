generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                   String               @id @default(uuid())
  email                String               @unique
  username             String               @unique
  displayName          String
  shortName            String?
  role                 String
  legacyRole           String
  team                 String?
  legacyTeam           String?
  specificRole         String?
  permissions          Json                 @default("[]")
  isActive             Boolean              @default(true)
  passwordResetRequired Boolean             @default(false)
  lastLoginAt          DateTime?
  emailConfirmedAt     DateTime?
  passwordHash         String
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  refreshTokens        RefreshToken[]
  passwordResetTokens  PasswordResetToken[]
  auditLogs            AuditLog[]
  laborFile            LaborFile?
}

model LaborFile {
  id                 String                @id @default(uuid())
  userId             String?               @unique
  employeeName       String
  employeeEmail      String?
  employeeUsername   String
  employeeShortName  String?
  team               String?
  legacyTeam         String?
  specificRole       String?
  status             String                @default("INCOMPLETE")
  employmentStatus   String                @default("ACTIVE")
  hireDate           DateTime              @db.Date
  employmentEndedAt  DateTime?             @db.Date
  notes              String?
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt
  user               User?                 @relation(fields: [userId], references: [id], onDelete: SetNull)
  documents          LaborFileDocument[]
  vacationEvents     LaborVacationEvent[]

  @@index([status, employmentStatus])
  @@index([employeeName])
}

model LaborFileDocument {
  id               String    @id @default(uuid())
  laborFileId      String
  documentType     String
  originalFileName String
  fileMimeType     String?
  fileSizeBytes    Int?
  fileContent      Bytes
  uploadedAt       DateTime  @default(now())
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  laborFile        LaborFile @relation(fields: [laborFileId], references: [id], onDelete: Cascade)

  @@index([laborFileId, documentType])
  @@index([uploadedAt])
}

model LaborVacationEvent {
  id                         String    @id @default(uuid())
  laborFileId                String
  eventType                  String
  startDate                  DateTime? @db.Date
  endDate                    DateTime? @db.Date
  vacationDates              Json?
  days                       Decimal   @default(0) @db.Decimal(6, 2)
  description                String?
  acceptanceOriginalFileName String?
  acceptanceFileMimeType     String?
  acceptanceFileSizeBytes    Int?
  acceptanceFileContent      Bytes?
  createdAt                  DateTime  @default(now())
  updatedAt                  DateTime  @updatedAt
  laborFile                  LaborFile @relation(fields: [laborFileId], references: [id], onDelete: Cascade)

  @@index([laborFileId, eventType])
  @@index([startDate, endDate])
}

model LaborGlobalVacationDay {
  id          String   @id @default(uuid())
  date        DateTime @unique @db.Date
  days        Decimal  @default(1) @db.Decimal(6, 2)
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([date])
}

model RefreshToken {
  id         String   @id @default(uuid())
  userId     String
  tokenHash  String   @unique
  expiresAt  DateTime
  revokedAt  DateTime?
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, revokedAt])
}

model PasswordResetToken {
  id         String   @id @default(uuid())
  userId     String
  tokenHash  String   @unique
  purpose    String
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, consumedAt, expiresAt])
}

model Client {
  id           String   @id @default(uuid())
  clientNumber String   @unique
  name         String
  deletedAt    DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  quotes       Quote[]
  leads        Lead[]
  matters      Matter[]
  internalContracts InternalContract[]
  dailyDocumentAssignments DailyDocumentAssignment[]

  @@index([deletedAt, clientNumber])
}

model InternalContract {
  id                String   @id @default(uuid())
  contractNumber    String   @unique
  contractType      String
  documentKind      String   @default("CONTRACT")
  clientId          String?
  clientNumber      String?
  clientName        String?
  collaboratorName  String?
  originalFileName  String?
  fileMimeType      String?
  fileSizeBytes     Int?
  fileContent       Bytes?
  paymentMilestones Json     @default("[]")
  notes             String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  client            Client?  @relation(fields: [clientId], references: [id], onDelete: SetNull)

  @@index([contractType, contractNumber])
  @@index([clientId])
  @@index([collaboratorName])
}

model InternalContractTemplate {
  id               String   @id @default(uuid())
  title            String
  originalFileName String
  fileMimeType     String?
  fileSizeBytes    Int?
  fileContent      Bytes
  notes            String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([title])
  @@index([createdAt])
}

model DailyDocumentAssignment {
  id            String   @id @default(uuid())
  templateId    String
  templateTitle String
  title         String
  clientId      String
  clientNumber  String
  clientName    String
  values        Json     @default("{}")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  client        Client   @relation(fields: [clientId], references: [id], onDelete: Restrict)

  @@index([clientId, createdAt])
  @@index([templateId, createdAt])
  @@index([createdAt])
}

model Quote {
  id          String   @id @default(uuid())
  quoteNumber String   @unique
  clientId    String
  clientName  String
  responsibleTeam String?
  subject     String
  status      String
  quoteType   String
  language    String   @default("es")
  quoteDate   DateTime @default(now()) @db.Date
  amountColumns Json?
  tableRows   Json?
  lineItems   Json
  totalMxn    Decimal
  milestone   String?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  client      Client   @relation(fields: [clientId], references: [id], onDelete: Restrict)
  leads       Lead[]
  matters     Matter[]
}

model QuoteTemplate {
  id             String   @id @default(uuid())
  templateNumber String?  @unique
  name           String
  team           String
  subject        String
  services       String?
  quoteType      String
  amountColumns  Json?
  tableRows      Json?
  lineItems      Json
  totalMxn       Decimal
  milestone      String?
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([team, name])
  @@index([createdAt])
}

model Lead {
  id                   String   @id @default(uuid())
  clientId             String?
  quoteId              String?
  clientName           String   @default("")
  prospectName         String?
  commissionAssignee   String?
  quoteNumber          String?
  subject              String   @default("")
  amountMxn            Decimal  @default(0)
  communicationChannel String   @default("WHATSAPP")
  lastInteractionLabel String?
  lastInteraction      DateTime?
  nextInteractionLabel String?
  nextInteraction      DateTime?
  notes                String?
  sentToClientAt       DateTime?
  sentToMattersAt      DateTime?
  hiddenFromTracking   Boolean  @default(false)
  status               String   @default("ACTIVE")
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  client               Client?  @relation(fields: [clientId], references: [id], onDelete: SetNull)
  quote                Quote?   @relation(fields: [quoteId], references: [id], onDelete: SetNull)

  @@index([status, hiddenFromTracking, sentToMattersAt])
  @@index([sentToClientAt])
}

model Matter {
  id                   String   @id @default(uuid())
  matterNumber         String   @unique
  clientId             String?
  clientNumber         String?
  quoteId              String?
  clientName           String   @default("")
  quoteNumber          String?
  commissionAssignee   String?
  matterType           String   @default("ONE_TIME")
  subject              String   @default("")
  specificProcess      String?
  totalFeesMxn         Decimal  @default(0)
  responsibleTeam      String?
  nextPaymentDate      DateTime?
  communicationChannel String   @default("WHATSAPP")
  r1InternalCreated    Boolean  @default(false)
  telegramBotLinked    Boolean  @default(false)
  rdCreated            Boolean  @default(false)
  rfCreated            String   @default("NO")
  r1ExternalCreated    Boolean  @default(false)
  billingChatCreated   Boolean  @default(false)
  matterIdentifier     String?
  executionLinkedModule String?
  executionLinkedAt    DateTime?
  executionPrompt      String?
  holidayAuthorityShortName String?
  nextAction           String?
  nextActionDueAt      DateTime?
  nextActionSource     String?
  milestone            String?
  concluded            Boolean  @default(false)
  stage                String   @default("INTAKE")
  origin               String   @default("MANUAL")
  notes                String?
  deletedAt            DateTime?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  client               Client?  @relation(fields: [clientId], references: [id], onDelete: SetNull)
  quote                Quote?   @relation(fields: [quoteId], references: [id], onDelete: SetNull)
  tasks                TaskItem[]

  @@index([deletedAt, createdAt])
  @@index([matterType, deletedAt])
  @@index([quoteNumber])
}

model GeneralExpense {
  id                 String    @id @default(uuid())
  year               Int
  month              Int
  detail             String    @default("")
  amountMxn          Decimal   @default(0)
  countsTowardLimit  Boolean   @default(false)
  team               String    @default("Sin equipo")
  generalExpense     Boolean   @default(false)
  expenseWithoutTeam Boolean   @default(false)
  pctLitigation      Decimal   @default(0)
  pctCorporateLabor  Decimal   @default(0)
  pctSettlements     Decimal   @default(0)
  pctFinancialLaw    Decimal   @default(0)
  pctTaxCompliance   Decimal   @default(0)
  paymentMethod      String    @default("Transferencia")
  bank               String?
  recurring          Boolean   @default(false)
  approvedByEmrt     Boolean   @default(false)
  paidByEmrtAt       DateTime? @db.Date
  reviewedByJnls     Boolean   @default(false)
  paid               Boolean   @default(false)
  paidAt             DateTime? @db.Date
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@index([year, month, createdAt])
}

model BudgetPlan {
  id                 String   @id @default(uuid())
  year               Int
  month              Int
  expectedIncomeMxn  Decimal  @default(0)
  expectedExpenseMxn Decimal  @default(0)
  notes              String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@unique([year, month])
  @@index([year, month])
}

model BudgetPlanSnapshot {
  id                  String   @id @default(uuid())
  year                Int
  month               Int
  expectedIncomeMxn   Decimal  @default(0)
  expectedExpenseMxn  Decimal  @default(0)
  actualIncomeMxn     Decimal  @default(0)
  actualExpenseMxn    Decimal  @default(0)
  expectedResultMxn   Decimal  @default(0)
  actualResultMxn     Decimal  @default(0)
  financeRecordCount  Int      @default(0)
  generalExpenseCount Int      @default(0)
  notes               String?
  createdAt           DateTime @default(now())

  @@unique([year, month])
  @@index([year, month, createdAt])
}

model CommissionReceiver {
  id        String   @id @default(uuid())
  name      String   @unique
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
}

model FinanceRecord {
  id                         String   @id @default(uuid())
  year                       Int
  month                      Int
  clientNumber               String?
  clientName                 String   @default("")
  quoteNumber                String?
  matterType                 String   @default("ONE_TIME")
  subject                    String   @default("")
  contractSignedStatus       String   @default("NO")
  responsibleTeam            String?
  totalMatterMxn             Decimal  @default(0)
  workingConcepts            String?
  conceptFeesMxn             Decimal  @default(0)
  previousPaymentsMxn        Decimal  @default(0)
  nextPaymentDate            DateTime?
  nextPaymentNotes           String?
  paidThisMonthMxn           Decimal  @default(0)
  payment2Mxn                Decimal  @default(0)
  payment3Mxn                Decimal  @default(0)
  paymentDate1               DateTime?
  paymentDate2               DateTime?
  paymentDate3               DateTime?
  expenseNotes1              String?
  expenseNotes2              String?
  expenseNotes3              String?
  expenseAmount1Mxn          Decimal  @default(0)
  expenseAmount2Mxn          Decimal  @default(0)
  expenseAmount3Mxn          Decimal  @default(0)
  pctLitigation              Int      @default(0)
  pctCorporateLabor          Int      @default(0)
  pctSettlements             Int      @default(0)
  pctFinancialLaw            Int      @default(0)
  pctTaxCompliance           Int      @default(0)
  clientCommissionRecipient  String?
  closingCommissionRecipient String?
  milestone                  String?
  concluded                  Boolean  @default(false)
  financeComments            String?
  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt

  @@index([year, month, createdAt])
  @@index([year, month, quoteNumber])
  @@index([year, month, clientName, subject])
}

model FinanceSnapshot {
  id              String   @id @default(uuid())
  year            Int
  month           Int
  title           String
  totalIncomeMxn  Decimal  @default(0)
  totalExpenseMxn Decimal  @default(0)
  balanceMxn      Decimal  @default(0)
  snapshotData    Json?
  createdAt       DateTime @default(now())

  @@index([year, month, createdAt])
}

model CommissionSnapshot {
  id          String   @id @default(uuid())
  year        Int
  month       Int
  section     String
  title       String
  totalNetMxn Decimal  @default(0)
  snapshotData Json?
  createdAt   DateTime @default(now())

  @@index([year, month, section, createdAt])
}

model TaskModule {
  id        String      @id
  team      String
  label     String
  summary   String
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  tracks    TaskTrack[]
  tasks     TaskItem[]
}

model TaskTrack {
  id             String   @id @default(uuid())
  moduleId       String
  trackCode      String
  label          String
  mode           String
  recurring      Boolean  @default(false)
  recurrenceRule Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  module         TaskModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@unique([moduleId, trackCode])
}

model TaskItem {
  id           String     @id @default(uuid())
  moduleId     String
  trackId      String
  clientName   String
  matterId     String?
  matterNumber String?
  subject      String
  responsible  String
  dueDate      DateTime
  state        String
  recurring    Boolean    @default(false)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  matter       Matter?    @relation(fields: [matterId], references: [id], onDelete: SetNull)
  module       TaskModule @relation(fields: [moduleId], references: [id], onDelete: Restrict)

  @@index([moduleId, trackId, state, dueDate])
}

model TaskTrackingRecord {
  id               String   @id @default(uuid())
  moduleId         String
  tableCode        String
  sourceTable      String
  matterId         String?
  matterNumber     String?
  clientNumber     String?
  clientName       String   @default("")
  subject          String   @default("")
  specificProcess  String?
  matterIdentifier String?
  taskName         String   @default("")
  eventName        String?
  responsible      String   @default("")
  dueDate          DateTime? @db.Date
  termDate         DateTime? @db.Date
  completedAt      DateTime?
  status           String   @default("pendiente")
  workflowStage    Int      @default(1)
  reportedMonth    String?
  termId           String?
  data             Json     @default("{}")
  deletedAt        DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([moduleId, tableCode, status, dueDate])
  @@index([sourceTable, status])
  @@index([matterId])
}

model TaskTerm {
  id               String   @id @default(uuid())
  moduleId         String
  sourceTable      String?
  sourceRecordId   String?
  matterId         String?
  matterNumber     String?
  clientNumber     String?
  clientName       String   @default("")
  subject          String   @default("")
  specificProcess  String?
  matterIdentifier String?
  eventName        String   @default("")
  pendingTaskLabel String?
  responsible      String   @default("")
  dueDate          DateTime? @db.Date
  termDate         DateTime? @db.Date
  status           String   @default("pendiente")
  recurring        Boolean  @default(false)
  reportedMonth    String?
  verification     Json     @default("{}")
  data             Json     @default("{}")
  deletedAt        DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([moduleId, status, termDate])
  @@index([sourceTable, sourceRecordId])
}

model TaskDistributionEvent {
  id              String   @id @default(uuid())
  moduleId        String
  name            String
  targetTables    Json     @default("[]")
  defaultTaskName String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([moduleId, name])
}

model TaskDistributionHistory {
  id               String   @id @default(uuid())
  moduleId         String
  matterId         String?
  matterNumber     String?
  clientNumber     String?
  clientName       String   @default("")
  subject          String   @default("")
  specificProcess  String?
  matterIdentifier String?
  eventName        String   @default("")
  targetTables     Json     @default("[]")
  eventNamesPerTable Json   @default("[]")
  createdIds       Json     @default("{}")
  data             Json     @default("{}")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([moduleId, createdAt])
  @@index([matterId])
}

model TaskAdditionalTask {
  id           String   @id @default(uuid())
  moduleId     String
  task          String
  responsible  String
  responsible2 String?
  dueDate      DateTime? @db.Date
  recurring    Boolean  @default(false)
  status       String   @default("pendiente")
  deletedAt    DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([moduleId, status, dueDate])
}

model Holiday {
  id                 String   @id @default(uuid())
  date               DateTime @db.Date
  authorityShortName String   @default("PJF")
  authorityName      String   @default("Poder Judicial de la Federacion")
  label              String   @default("Dia inhabil")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@unique([authorityShortName, date])
  @@index([date])
  @@index([authorityShortName, date])
}

model AuditLog {
  id         String   @id @default(uuid())
  userId     String?
  action     String
  entityType String
  entityId   String
  payload    Json?
  createdAt  DateTime @default(now())
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([entityType, entityId, createdAt])
}

model LegacyImportBatch {
  id         String              @id @default(uuid())
  source     String
  exportName String?
  exportedAt DateTime?
  appliedAt  DateTime?
  summary    Json?
  createdAt  DateTime            @default(now())
  rows       LegacyImportArchive[]

  @@index([source, createdAt])
}

model LegacyImportArchive {
  id          String            @id @default(uuid())
  batchId     String
  legacyTable String
  legacyId    String?
  entityType  String
  payload     Json
  createdAt   DateTime          @default(now())
  batch       LegacyImportBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)

  @@index([batchId, legacyTable])
  @@index([legacyTable, legacyId])
  @@index([entityType, createdAt])
}
