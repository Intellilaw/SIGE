# SIGE_2 environment template.
# Do not store real production secrets in this file.
# Use APP_ENV=local on developer machines and APP_ENV=production only in AWS.

APP_ENV=local
API_PORT=4000
WEB_PORT=5173
API_ORIGIN=http://localhost:4000
WEB_ORIGIN=http://localhost:5173

# Local development must use local PostgreSQL only.
# Replace the placeholders with your local PostgreSQL user, password, and database.
# Never paste an AWS RDS production URL in local env files.
DATABASE_URL=postgresql://<local_user>:<local_password>@localhost:5432/<local_database>?schema=public

# Local PostgreSQL helper settings used by npm run dev:local:api.
SIGE_SKIP_LOCAL_POSTGRES=false
SIGE_LOCAL_POSTGRES_PORT=5432

# RDS is production-only. Local development rejects SIGE_USE_RDS_TUNNEL=true.
SIGE_USE_RDS_TUNNEL=false
SIGE_RDS_TUNNEL_REQUIRED=false
SIGE_LOCAL_DATABASE_URL=
SIGE_AWS_REGION=us-east-1
SIGE_AWS_APP_SECRET_ID=
SIGE_RDS_TUNNEL_INSTANCE_ID=
SIGE_RDS_TUNNEL_REMOTE_HOST=
SIGE_RDS_TUNNEL_LOCAL_PORT=15433

# Use at least 32 characters for JWT secrets.
JWT_ACCESS_SECRET=replace-with-at-least-32-character-local-secret
JWT_REFRESH_SECRET=replace-with-another-32-character-local-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
AUTH_COOKIE_DOMAIN=
AUTH_COOKIE_SAME_SITE=lax

MANAGER_DE_ESCRITOS_URL=http://localhost:8000
SSO_SECRET_KEY=replace-with-the-shared-manager-sso-secret
SSO_ISSUER=sige
SSO_AUDIENCE=manager-de-escritos
PASSWORD_RESET_TTL_MINUTES=120
PASSWORD_RESET_EXPOSE_PREVIEW=false

OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_QUOTE_TRANSLATION_MODEL=gpt-4o-mini
OPENAI_QUOTE_TRANSLATION_TIMEOUT_MS=45000
OPENAI_LABOR_CONTRACT_MODEL=gpt-4o-mini
OPENAI_LABOR_CONTRACT_TIMEOUT_MS=60000
OPENAI_EXTERNAL_CONTRACT_MODEL=gpt-4o-mini
OPENAI_EXTERNAL_CONTRACT_TIMEOUT_MS=60000
OPENAI_RUSCONI_INTELLIGENCE_MODEL=gpt-5.5
OPENAI_RUSCONI_INTELLIGENCE_TIMEOUT_MS=60000

INTELLILAW_BOT_API_URL=http://localhost:8000
INTELLILAW_BOT_API_KEY=
INTELLILAW_BOT_PROMOTION_TIMEOUT_MS=180000
TELEGRAM_BOT_TOKEN=
TELEGRAM_GROUP_LOOKUP_TIMEOUT_MS=5000

# AWS production values belong in AWS Secrets Manager / deployment configuration.
AWS_REGION=us-east-1
AWS_RDS_SECRET_ARN=
AWS_S3_DOCUMENT_BUCKET=

# Google Workspace OAuth. In local development, SIGE also checks
# %LOCALAPPDATA%\SIGE\secrets\google-oauth-client.json automatically.
GOOGLE_WORKSPACE_OAUTH_CLIENT_FILE=
GOOGLE_WORKSPACE_OAUTH_CLIENT_ID=
GOOGLE_WORKSPACE_OAUTH_CLIENT_SECRET=
GOOGLE_WORKSPACE_OAUTH_REDIRECT_URI=http://localhost:4000/api/v1/google-workspace/oauth/callback
GOOGLE_WORKSPACE_TOKEN_ENCRYPTION_SECRET=
